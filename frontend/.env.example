EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# Google Maps Platform — web (Maps JavaScript API). Restríngela por HTTP referrer.
EXPO_PUBLIC_GOOGLE_MAPS_WEB_KEY=

# Google Maps Platform — nativos. Solo se leen en build/prebuild por app.config.ts.
# NO usar prefijo EXPO_PUBLIC_ — no deben quedar embebidas en el bundle JS.
IOS_GOOGLE_MAPS_API_KEY=
ANDROID_GOOGLE_MAPS_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BUCKET_URL=
BUCKET_NAME=